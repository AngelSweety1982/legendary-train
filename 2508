from collections import defaultdict

class Solution:
    def isPossible(self, n: int, edges: list[list[int]]) -> bool:
        adj = defaultdict(set)
        for u, v in edges:
            adj[u].add(v)
            adj[v].add(u)
        
        odd = [i for i in range(1, n + 1) if len(adj[i]) % 2 != 0]
        
        if not odd: return True
        if len(odd) > 4 or len(odd) % 2 != 0: return False
        
        # Check pairings for 2 or 4 nodes
        if len(odd) == 2:
            a, b = odd
            if b not in adj[a]: return True
            return any(i not in adj[a] and i not in adj[b] for i in range(1, n + 1))
        
        if len(odd) == 4:
            a, b, c, d = odd
            return (b not in adj[a] and d not in adj[c]) or \
                   (c not in adj[a] and d not in adj[b]) or \
                   (d not in adj[a] and c not in adj[b])
        return False
