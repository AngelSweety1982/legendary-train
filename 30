from collections import Counter

class Solution:
    def findSubstring(self, s: str, words: list[str]) -> list[int]:
        if not s or not words:
            return []
        
        word_len = len(words[0])
        word_count = len(words)
        total_len = word_len * word_count
        word_freq = Counter(words)
        results = []
        
        # We only need to start from offsets 0 to word_len - 1
        for i in range(word_len):
            left = i
            right = i
            current_count = Counter()
            count = 0
            
            # Slide the window across the string in word_len steps
            while right + word_len <= len(s):
                word = s[right : right + word_len]
                right += word_len
                
                if word in word_freq:
                    current_count[word] += 1
                    count += 1
                    
                    # If we have too many instances of 'word', shift left
                    while current_count[word] > word_freq[word]:
                        left_word = s[left : left + word_len]
                        current_count[left_word] -= 1
                        count -= 1
                        left += word_len
                    
                    # If count matches total words, we found a valid starting index
                    if count == word_count:
                        results.append(left)
                else:
                    # Not a valid word, reset the window
                    current_count.clear()
                    count = 0
                    left = right
                    
        return results
