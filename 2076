class Solution:
    def friendRequests(self, n: int, restrictions: List[List[int]], requests: List[List[int]]) -> List[bool]:
        p = list(range(n))
        def find(x):
            if p[x] != x:
                p[x] = find(p[x])
            return p[x]
        
        ans = []
        for u, v in requests:
            root_u, root_v = find(u), find(v)
            if root_u == root_v:
                ans.append(True)
            else:
                valid = True
                for x, y in restrictions:
                    root_x, root_y = find(x), find(y)
                    # Check if merging root_u and root_v would connect restricted root_x and root_y
                    if (root_u == root_x and root_v == root_y) or \
                       (root_u == root_y and root_v == root_x):
                        valid = False
                        break
                
                ans.append(valid)
                if valid:
                    p[root_u] = root_v  # Union the groups
        return ans
